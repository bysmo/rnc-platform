# Variables d'environnement — copier en .env et adapter
# NE JAMAIS COMMITTER LE FICHIER .env

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rnc
POSTGRES_PASSWORD=rnc

# ============================================================
# Keycloak
# ============================================================
KEYCLOAK_URL=http://localhost:8090
KEYCLOAK_ADMIN_CLIENT=admin-cli
KEYCLOAK_ADMIN_SECRET=changeme

# ============================================================
# Eureka / Config Server
# ============================================================
EUREKA_URL=http://localhost:8761/eureka/
CONFIG_SERVER_URL=http://localhost:8888
CONFIG_PROFILE=native

# ============================================================
# Kafka / RabbitMQ
# ============================================================
KAFKA_URL=localhost:9092
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=rnc
RABBITMQ_PASSWORD=rnc

# ============================================================
# Sécurité (chiffrement / HSM)
# ============================================================
RNC_ENCRYPTION_KEY=  # Base64 — 32 bytes pour AES-256
RNC_ENCRYPTION_HSM_ENABLED=false

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ============================================================
# Observabilité
# ============================================================
RNC_LOKI_URL=http://localhost:3100/loki/api/v1/push
RNC_OTEL_ENDPOINT=http://localhost:4317

# ============================================================
# Mobile Money APIs (production: valeurs réelles)
# ============================================================
ORANGE_MONEY_API_URL=
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_MERCHANT_KEY=

MOOV_MONEY_API_URL=
MOOV_MONEY_API_KEY=

TELECEL_MONEY_API_URL=
TELECEL_MONEY_API_KEY=

# ============================================================
# SMS Gateway
# ============================================================
SMS_GATEWAY_URL=
SMS_GATEWAY_API_KEY=
SMS_SENDER=RNC
