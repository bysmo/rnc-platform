# ============================================================
# RNC — .gitignore
# ============================================================

# Maven
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# IDE
.idea/
*.iml
*.ipr
*.iws
.vscode/
.settings/
.project
.classpath
.factorypath
*.swp
*~

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Logs
logs/
*.log
log/

# Build
build/
dist/
out/
*.class
*.jar
*.war
!.mvn/wrapper/maven-wrapper.jar

# Spring Boot
*.original
spring-shell.log

# Properties sensibles — ne jamais committer
**/application-local.yml
**/application-prod.yml
**/application-secrets.yml
**/bootstrap-local.yml
**/bootstrap-prod.yml
*.env
.env
.env.*
!.env.example

# Keystores et certificats
*.jks
*.p12
*.pem
*.key
*.crt
*.cer
*.pfx

# Docker
docker-compose.override.yml

# Kotlin
*.kotlin_metadata

# Coverage
*.exec
coverage/
.jacoco/

# Test reports
**/surefire-reports/
**/failsafe-reports/
**/site/jacoco/

# Node / Frontend (si ajouté)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Flutter / Dart
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/build/
mobile/.packages
mobile/.pub-cache/
mobile/.pub/
mobile/pubspec.lock

# ASDF / SDKMAN
.tool-versions

# Sonar
.scannerwork/

# Helm
deploy/helm/charts/
deploy/helm/Chart.lock

# Temporary files
*.tmp
*.bak
*.orig
