@startuml C2-Container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title RNC — Diagramme C4 de Niveau 2 (Conteneurs)

' Personas
Person(citizen, "Citoyen", "Utilise l'app mobile")
Person(merchant, "Marchand", "Utilise portail web + scan QR")
Person(admin, "Admin", "Portail d'administration")

' Boundary
System_Boundary(rnc, "Réseau National de Confiance") {

    ' Client apps
    Container(mobile_app, "App Mobile", "Flutter 3.x", "iOS + Android — scan QR, demande crédit, signature dette")
    Container(admin_portal, "Portail Admin", "React + Vite", "Gestion marchands, audits, dashboards")

    ' Edge
    Container(api_gateway, "API Gateway", "Spring Cloud Gateway", "Routing, rate limiting, JWT validation")

    ' IAM
    Container(keycloak, "Keycloak", "Keycloak 25", "OIDC/OAuth2, MFA OTP SMS, RBAC")

    ' Infrastructure
    Container(eureka, "Eureka", "Spring Cloud Netflix", "Service discovery")
    Container(config, "Config Server", "Spring Cloud Config", "Configuration centralisée")

    ' Microservices métier (groupés)
    Container(trust_id, "Trust ID", "Spring Boot 3.4", "Identité citoyens, KYC, LCB-FT")
    Container(trust_score, "Trust Score", "Spring Boot 3.4", "Score dynamique, explicable")
    Container(trust_credit, "Trust Credit", "Spring Boot 3.4", "Nano-crédit, échéancier")
    Container(trust_escrow, "Trust Escrow", "Spring Boot 3.4", "Crédit affecté, déblocage progressif")
    Container(trust_qr, "Trust QR", "Spring Boot 3.4", "QR Code Confiance")
    Container(trust_debt, "Trust Debt", "Spring Boot 3.4", "Reconnaissance dette")
    Container(trust_others, "Trust School/Health/Farming/Insurance/Collect/Merchant", "Spring Boot 3.4", "Modules sectoriels")

    ' Async
    Container(kafka, "Apache Kafka", "Confluent 7.6", "Event streaming, audit immuable")
    Container(rabbit, "RabbitMQ", "3.13", "Tâches async, notifications")

    ' Data
    ContainerDb(postgres, "PostgreSQL", "16", "Données métier par service (multi-schémas)")
    ContainerDb(redis, "Redis", "7", "Cache, sessions, rate limit")
}

' External
System_Ext(mo_mo, "Mobile Money APIs", "Orange, Moov, Telecel")
System_Ext(sms, "Passerelle SMS", "OTP, notifications")

' Relations
Rel(citizen, mobile_app, "Utilise")
Rel(merchant, admin_portal, "Utilise")
Rel(admin, admin_portal, "Utilise")

Rel(mobile_app, api_gateway, "HTTPS/REST + JWT")
Rel(admin_portal, api_gateway, "HTTPS/REST + JWT")

Rel(api_gateway, keycloak, "Validate JWT (JWKS)")
Rel(api_gateway, trust_id, "Routes to")
Rel(api_gateway, trust_score, "Routes to")
Rel(api_gateway, trust_credit, "Routes to")
Rel(api_gateway, trust_escrow, "Routes to")
Rel(api_gateway, trust_qr, "Routes to")
Rel(api_gateway, trust_debt, "Routes to")
Rel(api_gateway, trust_others, "Routes to")

Rel(trust_id, eureka, "Register/discover")
Rel(trust_id, config, "Fetch config")

Rel(trust_credit, postgres, "Read/write")
Rel(trust_credit, kafka, "Publish events")
Rel(trust_credit, rabbit, "Enqueue tasks")

Rel(trust_score, kafka, "Consume credit events, publish score updates")
Rel(trust_escrow, kafka, "Publish release events")

Rel(mobile_app, mo_mo, "Deep link to pay")
Rel(trust_credit, mo_mo, "Disburse, collect repayments")
Rel(trust_id, sms, "Send OTP via worker")

LAY_UD

@enduml
