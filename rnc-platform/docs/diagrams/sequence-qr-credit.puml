@startuml Sequence-QR-Credit
title RNC — Séquence : Paiement par QR Code Confiance avec nano-crédit

actor "Citoyen" as citizen
participant "App Mobile\nFlutter" as app
participant "API Gateway" as gw
participant "Trust QR" as qr
participant "Trust Credit" as credit
participant "Trust Score" as score
participant "Trust Escrow" as escrow
database "PostgreSQL\ntrust_credit" as db_credit
participant "Kafka" as kafka
participant "Marchand\n(fournisseur)" as merchant

== Scan du QR Code ==

citizen -> app : Scan QR code marchand
app -> gw : POST /api/v1/qr/scan
gw -> qr : forwardRequest()
qr -> qr : Décoder QR (merchant_id + service_point_id)
qr -> merchant : Vérifier marchand agréé (Feign)
merchant --> qr : OK + catégorie (SCHOOL/HEALTH/...)
qr --> app : 200 OK {merchant, maxAmount, suggestedPurpose}

== Demande de crédit ==

citizen -> app : Saisir montant + durée
app -> gw : POST /api/v1/credits {citizenId, merchantId, amount, durationDays, purpose}
gw -> credit : forwardRequest()
credit -> score : GET /api/v1/score/{citizenId}
score --> credit : {score: 720, level: GOOD}
credit -> credit : Vérifier règles (max 3 crédits actifs, plafond 500k XOF)
credit -> db_credit : INSERT credit (status=REQUESTED)
credit -> kafka : publish rnc.credit.requested
credit -> credit : RiskEngine.evaluate(score, montant)
credit -> credit : Décision automatique (score > 650 → APPROUVED)

== Réservation Escrow ==

credit -> escrow : POST /api/v1/escrow/reserve {creditId, merchantId, amount, releaseRules}
escrow -> escrow : Créer compte escrow
escrow --> credit : {escrowAccountId, status=RESERVED}
credit -> db_credit : UPDATE credit SET escrow_account_id, status=APPROVED
credit -> kafka : publish rnc.credit.approved

== Déblocage immédiat partiel ==

credit -> escrow : POST /api/v1/escrow/{id}/release-rule/1/trigger
escrow -> escrow : Libère 50% immédiat
escrow -> merchant : Notifier (Kafka rnc.escrow.released)
escrow -> kafka : publish rnc.escrow.released

== Notification citoyen ==

credit --> app : 200 OK {creditId, status=APPROVED, escrowId, amountDisbursed}
app -> citizen : Afficher "Crédit accordé — aller chercher le bien"

== Plus tard : livraison / prestation ==

merchant -> qr : POST /api/v1/qr/validate-delivery {escrowId, deliveryProof}
qr -> escrow : Trigger release rule 2 (ON_DELIVERY)
escrow -> merchant : Libère 50% restant
escrow -> kafka : publish rnc.escrow.released (final)

@enduml
