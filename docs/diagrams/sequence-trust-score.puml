@startuml Sequence-Trust-Score
title RNC — Séquence : Mise à jour du Trust Score après remboursement

actor "Système Mobile Money" as mo_mo
participant "Trust Credit" as credit
participant "Kafka" as kafka
participant "Trust Score" as score
database "trust_credit DB" as db_credit
database "trust_score DB" as db_score
participant "App Mobile" as app

== Remboursement d'une échéance ==

mo_mo -> credit : Webhook paiement reçu {paymentRef, creditId, amount}
credit -> credit : Idempotency check (paymentRef)
credit -> db_credit : INSERT payment (status=COMPLETED)
credit -> db_credit : UPDATE repayment_schedule SET paid
credit -> credit : Vérifier si crédit totalement remboursé

alt Crédit entièrement remboursé
    credit -> db_credit : UPDATE credit SET status=COMPLETED
    credit -> kafka : publish rnc.credit.repaid {citizenId, creditId, totalAmount, onTime: true}
end

== Consommation par Trust Score ==

score -> kafka : Consume rnc.credit.repaid
score -> score : Calculer impact: +20 points (remboursement à temps)
score -> db_score : INSERT score_event {impact: +20, type: CREDIT_REPAID}
score -> score : Recalculer score global
score -> db_score : UPDATE scores SET score_value=740, version=2 (ancien: 720)
score -> db_score : INSERT score_history (immutable, audit)
score -> kafka : publish rnc.trust-score.updated {citizenId, newScore: 740, delta: +20}

== Notification citoyen ==

kafka -> app : Push notification (via FCM)
note right of app : "Votre Trust Score a augmenté à 740 — Félicitations !"

@enduml
